#!/usr/bin/env python

from google.appengine.ext import webapp
from google.appengine.ext.webapp import util


class MainHandler(webapp.RequestHandler):
    def get(self):
        self.response.out.write("""
        <html>
        <head>
            <title>Cloud Computing Project</title>

            <style>
                body {
                    margin: 0;
                    font-family: Arial;
                    background: #f4f8ff;
                }

                .header {
                    background: #1e3a8a;
                    color: white;
                    padding: 20px;
                    text-align: center;
                }

                .container {
                    width: 80%;
                    margin: 30px auto;
                    background: white;
                    padding: 30px;
                    border-radius: 12px;
                    box-shadow: 0px 0px 12px #bbb;
                }

                h1, h2 {
                    text-align: center;
                }

                p {
                    font-size: 18px;
                    color: #444;
                    line-height: 1.6;
                }

                table {
                    width: 100%;
                    border-collapse: collapse;
                    margin-top: 20px;
                }

                table, th, td {
                    border: 1px solid #ccc;
                }

                th {
                    background: #dbeafe;
                    padding: 12px;
                }

                td {
                    padding: 10px;
                    text-align: center;
                }

                .footer {
                    background: #1e3a8a;
                    color: white;
                    text-align: center;
                    padding: 15px;
                    margin-top: 30px;
                }
            </style>
        </head>

        <body>

            <div class="header">
                <h1>Cloud Computing Practical</h1>
                <h2>Google App Engine Web Application</h2>
            </div>

            <div class="container">
                <h2>Hello World Application</h2>

                <p>
                    This web application is developed using Python on
                    Google App Engine platform.
                </p>

                <p>
                    It demonstrates deployment and execution of a
                    simple cloud-based web application.
                </p>

                <table>
                    <tr>
                        <th>Assignment</th>
                        <th>Technology</th>
                    </tr>
                    <tr>
                        <td>Assignment 2</td>
                        <td>Install GAE + Hello World</td>
                    </tr>
                    <tr>
                        <td>Assignment 3</td>
                        <td>Launch Web App using GAE</td>
                    </tr>
                </table>
            </div>

            <div class="footer">
                Developed for Cloud Computing Lab
            </div>

        </body>
        </html>
        """)


def main():
    application = webapp.WSGIApplication(
        [('/', MainHandler)],
        debug=True
    )
    util.run_wsgi_app(application)


if __name__ == '__main__':
    main()

